{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node", "express", "pg", "vitest"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
